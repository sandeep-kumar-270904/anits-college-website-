# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app.py

# Application Settings
APP_SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration (if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/college_chat_db

# API Keys
# TRANSLATION_API_KEY=your-api-key-here
# GOOGLE_TRANSLATE_API_KEY=your-key-here

# PDF Processing Settings
MAX_PDF_SIZE=10
ALLOWED_FILE_EXTENSIONS=pdf,txt,doc,docx

# CORS Settings
CORS_ORIGINS=*

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
